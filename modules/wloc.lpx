#!name=Apple WLOC Location Spoofer
#!desc=Modify the coordinates returned by Apple's network-based location service (WiFi/cell) | Shortcuts (recommended): Set Location https://www.icloud.com/shortcuts/a82717d8fdad4e6280866fcf911173f7 Clear & Restore Location https://www.icloud.com/shortcuts/f42632d406504f24a2cd163af4fe012f
#!icon=https://raw.githubusercontent.com/cyberhandyman/wloc-spoofer-en/refs/heads/main/wloc.jpg
#!author=Yu9191 Rewrite
#!homepage=https://github.com/cyberhandyman/wloc-spoofer-en
#!openUrl=https://wloc-spoofer.cyberhandyman.workers.dev/

[Argument]
longitude = input, "113.94114", tag=Longitude (online picker takes priority)
latitude = input, "22.544577", tag=Latitude (online picker takes priority)
accuracy = input, "25", tag=Accuracy (meters)
logLevel = select, "info", "off", "error", "warn", "debug", "all", tag=Log level

[Script]
http-response ^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc script-path=https://raw.githubusercontent.com/cyberhandyman/wloc-spoofer-en/refs/heads/main/dist/wloc.js, requires-body=true, binary-body-mode=true, timeout=30, tag=Apple WLOC, argument=[{longitude},{latitude},{accuracy},{logLevel}]
http-request ^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save script-path=https://raw.githubusercontent.com/cyberhandyman/wloc-spoofer-en/refs/heads/main/dist/wloc-settings.js, timeout=10, tag=WLOC Settings

[MITM]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com
